default_platform(:ios)

platform :ios do
  desc "Build and upload iOS dev build to TestFlight"
  lane :ios_dev do
    # Required on macOS 15+ CI — creates a temporary keychain and exports
    # MATCH_KEYCHAIN_NAME/PASSWORD so match can import certs without GUI prompts
    setup_ci

    # Build the API key object once — reused by both match and pilot to avoid
    # redundant credential configuration
    api_key = app_store_connect_api_key(
      key_id:                ENV["APPLE_API_KEY_ID"],
      issuer_id:             ENV["APPLE_API_ISSUER_ID"],
      key_content:           ENV["APPLE_API_KEY_P8_BASE64"],
      is_key_content_base64: true,
      in_house:              false
    )

    # Fetch distribution cert + provisioning profile from mieweb/mobile-signing
    # readonly: true — CI only consumes certs, never creates or renews them
    match(
      type:           "appstore",
      app_identifier: "org.mieweb.os.dev",
      readonly:       true,
      api_key:        api_key
    )

    # Archive + export the IPA; workspace and scheme are resolved by the
    # workflow before invoking this lane and passed in as env vars.
    # xcargs injects DEVELOPMENT_TEAM + manual signing because the Cordova-
    # generated Xcode project does not set a development team by default,
    # and PROVISIONING_PROFILE_SPECIFIER pins it to the match-managed profile.
    gym(
      workspace:      ENV["WORKSPACE_PATH"],
      scheme:         ENV["XCODE_SCHEME"],
      configuration:  "Release",
      export_method:  "app-store",
      xcargs:         "CODE_SIGN_STYLE=Manual " \
                      "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} " \
                      "PROVISIONING_PROFILE_SPECIFIER=\"match AppStore org.mieweb.os.dev\"",
      export_options: {
        provisioningProfiles: {
          "org.mieweb.os.dev" => "match AppStore org.mieweb.os.dev"
        }
      }
    )

    # skip_waiting_for_build_processing avoids a ~30-min CI block;
    # the build still processes normally and appears in TestFlight async
    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
